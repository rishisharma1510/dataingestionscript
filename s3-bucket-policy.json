{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyDeleteProtectedFolders",
      "Effect": "Deny",
      "Principal": "*",
      "Action": [
        "s3:DeleteObject",
        "s3:DeleteObjectVersion"
      ],
      "Resource": [
        "arn:aws:s3:::${BUCKET_NAME}/synergy-drive/",
        "arn:aws:s3:::${BUCKET_NAME}/inbox/",
        "arn:aws:s3:::${BUCKET_NAME}/outbox/",
        "arn:aws:s3:::${BUCKET_NAME}/quarantine/"
      ]
    },

    {
      "Sid": "DenyGetObjectIfNotCleanOnSynergyDrive",
      "Effect": "Deny",
      "Principal": "*",
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::${BUCKET_NAME}/synergy-drive/*",
      "Condition": {
        "StringEquals": {
          "s3:ExistingObjectTag/isClean": "false"
        },
        "StringNotLike": {
          "aws:PrincipalArn": "${VIRUS_SCAN_ROLE_ARN}"
        }
      }
    },

    {
      "Sid": "TenantRoleAllowAllActions",
      "Effect": "Allow",
      "Principal": {
        "AWS": "${TENANT_ROLE_ARN}"
      },
      "Action": "s3:*",
      "Resource": [
        "arn:aws:s3:::${BUCKET_NAME}",
        "arn:aws:s3:::${BUCKET_NAME}/*"
      ]
    },
    {
      "Sid": "TenantRoleDenyPutDeleteOnSynergyDriveInbox",
      "Effect": "Deny",
      "Principal": {
        "AWS": "${TENANT_ROLE_ARN}"
      },
      "Action": [
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:DeleteObjectVersion"
      ],
      "Resource": "arn:aws:s3:::${BUCKET_NAME}/synergy-drive/inbox/*"
    },
    {
      "Sid": "TenantRoleDenyDownloadIfNotCleanOnSynergyDrive",
      "Effect": "Deny",
      "Principal": {
        "AWS": "${TENANT_ROLE_ARN}"
      },
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::${BUCKET_NAME}/synergy-drive/*",
      "Condition": {
        "StringEquals": {
          "s3:ExistingObjectTag/isClean": "false"
        }
      }
    },

    {
      "Sid": "CftRoleAllowAllOnInboxOutboxQuarantine",
      "Effect": "Allow",
      "Principal": {
        "AWS": "${CFT_ROLE_ARN}"
      },
      "Action": "s3:*",
      "Resource": [
        "arn:aws:s3:::${BUCKET_NAME}/inbox/*",
        "arn:aws:s3:::${BUCKET_NAME}/outbox/*",
        "arn:aws:s3:::${BUCKET_NAME}/quarantine/*"
      ]
    },
    {
      "Sid": "CftRoleAllowListBucket",
      "Effect": "Allow",
      "Principal": {
        "AWS": "${CFT_ROLE_ARN}"
      },
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::${BUCKET_NAME}",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "inbox/*",
            "outbox/*",
            "quarantine/*"
          ]
        }
      }
    },
    {
      "Sid": "CftRoleDenyDownloadIfNotCleanInboxOutbox",
      "Effect": "Deny",
      "Principal": {
        "AWS": "${CFT_ROLE_ARN}"
      },
      "Action": "s3:GetObject",
      "Resource": [
        "arn:aws:s3:::${BUCKET_NAME}/inbox/*",
        "arn:aws:s3:::${BUCKET_NAME}/outbox/*"
      ],
      "Condition": {
        "StringEquals": {
          "s3:ExistingObjectTag/isClean": "false"
        }
      }
    },

    {
      "Sid": "VirusScanRoleAllowSynergyDriveAndQuarantine",
      "Effect": "Allow",
      "Principal": {
        "AWS": "${VIRUS_SCAN_ROLE_ARN}"
      },
      "Action": "s3:*",
      "Resource": [
        "arn:aws:s3:::${BUCKET_NAME}/synergy-drive/*",
        "arn:aws:s3:::${BUCKET_NAME}/quarantine/*"
      ]
    },
    {
      "Sid": "VirusScanRoleAllowListBucket",
      "Effect": "Allow",
      "Principal": {
        "AWS": "${VIRUS_SCAN_ROLE_ARN}"
      },
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::${BUCKET_NAME}",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "synergy-drive/*",
            "quarantine/*"
          ]
        }
      }
    }
  ]
}
